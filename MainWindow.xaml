<Window x:Class="SmartCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartCalculator.ViewModels"
        Title="SmartCalculator"
        Icon="Assets/AppIcon.ico"
        Width="444"
        Height="830"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.TabNavigation="None"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:BooleanToOpacityConverter x:Key="BoolToOpacity"/>
    </Window.Resources>

    <Border Margin="0" CornerRadius="32" Background="#050606">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="10" Color="#000000" Opacity="0.58"/>
        </Border.Effect>

        <!-- Calculator body -->
        <Border CornerRadius="26" Margin="6" BorderBrush="#1D2123" BorderThickness="1"
                Background="{StaticResource BodyGradient}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="2" Color="#000000" Opacity="0.15" Direction="270"/>
            </Border.Effect>

            <Grid Margin="0,0,0,0">
                <!-- Inner subtle border overlay -->
                <Border CornerRadius="21" Margin="6" BorderBrush="#0DFFFFFF" BorderThickness="1" IsHitTestVisible="False"/>

                <!-- Main content area -->
                <Grid Margin="14,12,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="84"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="18"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- ========== ROW 0: HEADER (draggable) ========== -->
                <Grid Grid.Row="0" Margin="2,2,2,0" Background="Transparent"
                      MouseLeftButtonDown="HeaderDragArea_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Brand -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,1,0,0">
                        <TextBlock Text="SmartCalculator" Foreground="#F1F3F5" FontSize="20"
                                   FontWeight="ExtraBold" LineHeight="22"/>
                        <TextBlock Foreground="#AEB4BC" FontSize="8"
                                   FontWeight="ExtraBold" LineHeight="9"
                                   Margin="0,1,0,0">
                            <Run Text="Scientific Display" />
                            <Run Text="|" Foreground="#6A7078"/>
                            <Run Text="by: Ahmad Ibrahim" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Solar panel -->
                    <Border Grid.Column="1" Height="24" Width="110" Margin="0,2,0,0"
                            Background="#0A0C0D" CornerRadius="4" BorderBrush="#1D2123" BorderThickness="1"
                            HorizontalAlignment="Center">
                        <Grid Margin="3,0,3,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border Grid.Column="0" Margin="1,2" CornerRadius="1" Background="#111516" BorderBrush="#050606" BorderThickness="1"/>
                            <Border Grid.Column="1" Margin="1,2" CornerRadius="1" Background="#111516" BorderBrush="#050606" BorderThickness="1"/>
                            <Border Grid.Column="2" Margin="1,2" CornerRadius="1" Background="#111516" BorderBrush="#050606" BorderThickness="1"/>
                            <Border Grid.Column="3" Margin="1,2" CornerRadius="1" Background="#111516" BorderBrush="#050606" BorderThickness="1"/>
                        </Grid>
                    </Border>

                    <!-- Top-right buttons: About + Pin + Close -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,1,0,0">
                        <Button Content="&#x24D8;" Style="{StaticResource PinButtonStyle}"
                                Command="{Binding InputCommand}" CommandParameter="ABOUT"
                                ToolTipService.HasDropShadow="False"
                                ToolTip="About"/>
                        <Button x:Name="PinButton" Content="&#x1F4CC;" Style="{StaticResource PinButtonStyle}"
                                Click="PinButton_Click" Margin="4,0,0,0"
                                ToolTipService.HasDropShadow="False"
                                ToolTip="Always on Top"/>
                        <Button Content="&#x2715;" Style="{StaticResource CloseButtonStyle}"
                                Click="CloseButton_Click" Margin="6,0,0,0"
                                ToolTipService.HasDropShadow="False"
                                ToolTip="Close"/>
                    </StackPanel>
                </Grid>

                <!-- ========== ROW 1: LCD DISPLAY ========== -->
                <Border Grid.Row="1" Margin="0,4,0,0" CornerRadius="12,12,17,17"
                        Background="#161B18" BorderBrush="#313A33" BorderThickness="1"
                        Padding="6">
                    <Border CornerRadius="7,7,13,13" Background="#536051"
                            BorderBrush="#657164" BorderThickness="1" Padding="4">
                        <Border CornerRadius="5,5,11,11" Background="{StaticResource LCDBackground}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top shadow on LCD -->
                                <Rectangle Grid.Row="0" Height="6" VerticalAlignment="Top" Opacity="0.35"
                                           IsHitTestVisible="False">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#30000000" Offset="0"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Status line: S A DEG HYP BASE DEC Math -->
                                <Grid Grid.Row="0" Margin="9,6,9,0">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="Auto"/>
                                         <ColumnDefinition Width="*"/>
                                         <ColumnDefinition Width="Auto"/>
                                     </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="S" Style="{StaticResource LcdStatusText}"
                                               Opacity="{Binding IsShiftActive, Converter={StaticResource BoolToOpacity}}"
                                               Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="1" Text="A" Style="{StaticResource LcdStatusText}"
                                               Foreground="#8B3A3A"
                                               Opacity="{Binding IsAlphaActive, Converter={StaticResource BoolToOpacity}}"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AngleModeText, FallbackValue='DEG'}"
                                               Style="{StaticResource LcdStatusText}" Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="3" Text="HYP" Style="{StaticResource LcdStatusText}"
                                               Foreground="#3A6B8B"
                                               Visibility="{Binding IsHypActive, Converter={StaticResource BoolToVis}}"
                                               Margin="0,0,4,0"/>
                                    <TextBlock Grid.Column="4" Text="STAT" Style="{StaticResource LcdStatusText}"
                                               Foreground="#3A6B8B"
                                               Visibility="{Binding IsStatsActive, Converter={StaticResource BoolToVis}}"
                                               Margin="0,0,2,0"/>
                                    <TextBlock Grid.Column="5" Text="BASE" Style="{StaticResource LcdStatusText}"
                                               Foreground="#3A6B8B"
                                               Visibility="{Binding IsBaseNActive, Converter={StaticResource BoolToVis}}"
                                               Margin="0,0,2,0"/>
                                    <TextBlock Grid.Column="6" Text="CMPLX" Style="{StaticResource LcdStatusText}"
                                               Foreground="#3A6B8B"
                                               Visibility="{Binding IsCmplxActive, Converter={StaticResource BoolToVis}}"
                                               Margin="0,0,2,0"/>
                                     <TextBlock Grid.Column="7" Text="MATRIX" Style="{StaticResource LcdStatusText}"
                                                 Foreground="#3A6B8B"
                                                 Visibility="{Binding IsMatrixActive, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,2,0"/>
                                      <TextBlock Grid.Column="8" Text="EQN" Style="{StaticResource LcdStatusText}"
                                                 Foreground="#3A6B8B"
                                                 Visibility="{Binding IsEqnActive, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,2,0"/>
                                      <TextBlock Grid.Column="9" Text="VECTOR" Style="{StaticResource LcdStatusText}"
                                                 Foreground="#3A6B8B"
                                                 Visibility="{Binding IsVectorActive, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,2,0"/>
                                      <TextBlock Grid.Column="10" Text="TABLE" Style="{StaticResource LcdStatusText}"
                                                 Foreground="#3A6B8B"
                                                 Visibility="{Binding IsTableActive, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,2,0"/>
                                      <TextBlock Grid.Column="11"
                                                 Text="{Binding BaseLabel, FallbackValue='DEC'}"
                                                 Style="{StaticResource LcdStatusText}"
                                                 Foreground="#3A6B8B"
                                                 Visibility="{Binding IsBaseActive, Converter={StaticResource BoolToVis}}"
                                                 Margin="0,0,4,0"/>
                                      <TextBlock Grid.Column="13" Text="Math" Style="{StaticResource LcdStatusText}"
                                                 HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Expression line -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding ExpressionText, FallbackValue=''}"
                                            Foreground="#182018" FontSize="15"
                                           FontFamily="Consolas" FontWeight="SemiBold"
                                           VerticalAlignment="Bottom"
                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                            Margin="9,4,9,1"/>

                                <!-- ===== RESULT DISPLAY AREA (exclusive panels) ===== -->

                                <!-- Decimal result -->
                                <TextBlock Grid.Row="3"
                                           Text="{Binding ResultText, FallbackValue='0'}"
                                           Foreground="{Binding ResultBrush}"
                                           FontSize="26" FontFamily="Consolas" FontWeight="ExtraBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="9,0,9,5"
                                           Visibility="{Binding ShowDecimal, Converter={StaticResource BoolToVis}}"/>

                                <!-- Inline fraction (e.g. 3/4) -->
                                <TextBlock Grid.Row="3"
                                           Text="{Binding FracInlineText}"
                                           Foreground="{Binding ResultBrush}"
                                           FontSize="22" FontFamily="Consolas" FontWeight="ExtraBold"
                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="9,0,9,5"
                                           Visibility="{Binding ShowInlineFraction, Converter={StaticResource BoolToVis}}"/>

                                <!-- Stacked fraction (numerator / line / denominator) -->
                                <Border Grid.Row="3"
                                        Visibility="{Binding ShowStackedFraction, Converter={StaticResource BoolToVis}}"
                                        Background="Transparent"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="9,0,9,5">
                                    <Grid HorizontalAlignment="Right">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Sign + Numerator -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding FracSignDisplay}"
                                                       Foreground="{Binding ResultBrush}"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FracNumerator}"
                                                       Foreground="{Binding ResultBrush}"
                                                       FontSize="18" FontWeight="ExtraBold"
                                                       FontFamily="Consolas"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Fraction bar (vinculum) -->
                                        <Border Grid.Row="1" Height="2"
                                                Background="{Binding ResultBrush}"
                                                CornerRadius="1"
                                                HorizontalAlignment="Stretch"
                                                MinWidth="30"
                                                Margin="2,2"/>
                                        <!-- Denominator -->
                                        <TextBlock Grid.Row="2" Text="{Binding FracDenominator}"
                                                   Foreground="{Binding ResultBrush}"
                                                   FontSize="18" FontWeight="ExtraBold"
                                                   FontFamily="Consolas"
                                                   HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- ========== SETUP INSIDE LCD (replaces rows 1-3) ========== -->
                                <Grid Grid.Row="1" Grid.RowSpan="3"
                                      Visibility="{Binding ShowSetup, Converter={StaticResource BoolToVis}}"
                                      Panel.ZIndex="5" Margin="4,0,4,2"
                                      Background="{StaticResource LCDBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="MODE SETUP"
                                               Foreground="{StaticResource LCDTextBrush}"
                                               FontSize="11" FontWeight="ExtraBold" FontFamily="Consolas"
                                               Margin="2,2,0,1"/>
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding SetupDisplayItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel MaxWidth="220" Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource LCDTextBrush}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           FontFamily="Consolas"
                                                           Width="100" Margin="4,1,0,1"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <!-- ========== ABOUT INSIDE LCD ========== -->
                                <Grid Grid.Row="1" Grid.RowSpan="3"
                                      Visibility="{Binding ShowAbout, Converter={StaticResource BoolToVis}}"
                                      Panel.ZIndex="6" Margin="4,0,4,2"
                                      Background="{StaticResource LCDBackground}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Page indicator -->
                                    <TextBlock Grid.Row="0" Text="{Binding AboutPageText}"
                                               Foreground="{StaticResource LCDTextBrush}"
                                               FontSize="10" FontWeight="ExtraBold" FontFamily="Consolas"
                                               Margin="2,2,0,1"/>
                                    <!-- Title -->
                                    <TextBlock Grid.Row="1" Text="SmartCalculator"
                                               Foreground="{StaticResource LCDTextBrush}"
                                               FontSize="12" FontWeight="ExtraBold" FontFamily="Consolas"
                                               HorizontalAlignment="Center" Margin="0,2,0,2"/>
                                    <!-- About lines -->
                                    <ItemsControl Grid.Row="2"
                                                  ItemsSource="{Binding AboutDisplayItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource LCDTextBrush}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           FontFamily="Consolas"
                                                           Margin="4,1,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>
                    </Border>
                </Border>

                <!-- ========== ROW 2: TOP CONTROLS (Ovals + DPad) ========== -->
                <Grid Grid.Row="2" Margin="2,8,2,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: SHIFT / ALPHA ovals -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SHIFT" Foreground="#FFD84D" FontSize="10"
                                       FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="2,0,2,0" LineHeight="11"/>
                            <TextBlock Grid.Column="1" Text="ALPHA" Foreground="#E34B57" FontSize="10"
                                       FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="2,0,2,0" LineHeight="11"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Width="45" Height="30" Style="{StaticResource OvalKeyStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="SHIFT" Margin="0,0,5,0"/>
                            <Button Width="45" Height="30" Style="{StaticResource OvalKeyStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="ALPHA" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center: DPad navigation - true oval shape matching HTML border-radius: 50% -->
                    <Grid Grid.Column="1" Width="122" Height="72"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="2" Color="#000000" Opacity="0.22" Direction="270"/>
                        </Grid.Effect>
                        <Ellipse x:Name="DpadOuter" Stroke="#252B2D" StrokeThickness="2">
                            <Ellipse.Fill>
                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                    <GradientStop Color="#252B2D" Offset="0"/>
                                    <GradientStop Color="#1D2224" Offset="0.21"/>
                                    <GradientStop Color="#151819" Offset="0.43"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Grid Margin="0,0,0,0">
                            <!-- Inner inset ellipse -->
                            <Ellipse Width="60" Height="42" Stroke="#18FFFFFF" StrokeThickness="1"
                                     IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#00000000"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <!-- NAV label -->
                            <TextBlock Text="NAV" Foreground="#F4F6F7" FontSize="10" FontWeight="ExtraBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsHitTestVisible="False" Opacity="0.60"/>
                            <!-- Arrow buttons -->
                            <Button Content="▲" FontSize="14" Style="{StaticResource DpadButtonStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="UP"
                                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0"/>
                            <Button Content="▼" FontSize="14" Style="{StaticResource DpadButtonStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="DOWN"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            <Button Content="◀" FontSize="13" Style="{StaticResource DpadButtonStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="LEFT"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="9,0,0,0"/>
                            <Button Content="▶" FontSize="13" Style="{StaticResource DpadButtonStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="RIGHT"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,9,0"/>
                        </Grid>
                    </Grid>

                    <!-- Right: MODE / ON ovals -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="55"/>
                                <ColumnDefinition Width="55"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="2,0,2,0">
                                <TextBlock Text="MODE" Foreground="#F4F6F7" FontSize="10"
                                           FontWeight="ExtraBold" HorizontalAlignment="Center" LineHeight="12"/>
                                <TextBlock Text="SETUP" Foreground="#E34B57" FontSize="8"
                                           FontWeight="ExtraBold" HorizontalAlignment="Center" LineHeight="9"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="ON" Foreground="#F4F6F7" FontSize="10"
                                       FontWeight="ExtraBold" HorizontalAlignment="Center" Margin="2,0,2,0" LineHeight="12"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Width="45" Height="30" Style="{StaticResource OvalKeyStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="MODE" Margin="0,0,5,0"/>
                            <Button Width="45" Height="30" Style="{StaticResource OvalKeyStyle}"
                                    Command="{Binding InputCommand}" CommandParameter="ON" Margin="5,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ===== ROW 3: KEYPAD AREA ===== -->
                <Grid Grid.Row="3" Margin="2,6,2,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <!-- ===== ZONE 1: Command Strip (4 keys) ===== -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <!-- CALC -->
                        <Button Grid.Column="0" Content="CALC"
                                vm:ButtonExtensions.SecondaryLabel="SOLVE"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="CALC"/>
                        <!-- ∫ icon with placeholder box -->
                        <Button Grid.Column="1"
                                vm:ButtonExtensions.SecondaryLabel="d/dx" vm:ButtonExtensions.AlphaLabel="&#x2022;"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="INTEGRAL">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#x222B;" FontSize="16"/>
                                <Border Style="{StaticResource PlaceholderBoxStyle}"
                                        BorderBrush="{StaticResource KeyTextBrush}" Margin="1,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <!-- x⁻¹ -->
                        <Button Grid.Column="2" Content="x&#x207B;&#x00B9;"
                                vm:ButtonExtensions.SecondaryLabel="x!"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="INVERSE"/>
                        <!-- log with placeholder box -->
                        <Button Grid.Column="3"
                                vm:ButtonExtensions.SecondaryLabel="&#x03A3;" vm:ButtonExtensions.AlphaLabel="&#x25A5;"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="LOGAB">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="log" FontSize="15"/>
                                <Border Style="{StaticResource PlaceholderBoxStyle}"
                                        BorderBrush="{StaticResource KeyTextBrush}" Margin="1,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- ===== ZONE 2: Main Scientific Grid (6 cols × 3 rows) ===== -->
                    <Grid Grid.Row="1" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Sci Row 1: □/□ | √ | x² | xʸ | log | ln -->
                        <Button Grid.Row="0" Grid.Column="0"
                                vm:ButtonExtensions.SecondaryLabel="a b/c" vm:ButtonExtensions.AlphaLabel="d/c"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="FRAC" FontSize="11">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Style="{StaticResource PlaceholderBoxStyle}"
                                        BorderBrush="{StaticResource KeyTextBrush}" Margin="1,1,1,0"/>
                                <Border Height="1.5" Background="{StaticResource KeyTextBrush}" Margin="1,1" CornerRadius="0.5"/>
                                <Border Style="{StaticResource PlaceholderBoxStyle}"
                                        BorderBrush="{StaticResource KeyTextBrush}" Margin="1,0,1,1"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="1"
                                vm:ButtonExtensions.SecondaryLabel="&#x221B;" vm:ButtonExtensions.AlphaLabel="i"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="√" FontSize="15">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#x221A;" FontSize="15"/>
                                <Border Style="{StaticResource PlaceholderBoxStyle}"
                                        BorderBrush="{StaticResource KeyTextBrush}" Margin="1,1,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="2" Content="x&#x00B2;"
                                vm:ButtonExtensions.SecondaryLabel="x&#x00B3;" vm:ButtonExtensions.AlphaLabel="DEC"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="x²"/>
                        <Button Grid.Row="0" Grid.Column="3" Content="x&#x02B8;"
                                vm:ButtonExtensions.SecondaryLabel="&#x02B8;&#x221A;x" vm:ButtonExtensions.AlphaLabel="HEX"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="xʸ"/>
                        <Button Grid.Row="0" Grid.Column="4" Content="log"
                                vm:ButtonExtensions.SecondaryLabel="10&#x02E3;" vm:ButtonExtensions.AlphaLabel="BIN"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="log"/>
                        <Button Grid.Row="0" Grid.Column="5" Content="ln"
                                vm:ButtonExtensions.SecondaryLabel="e&#x02E3;" vm:ButtonExtensions.AlphaLabel="OCT"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="ln"/>

                        <!-- Sci Row 2: (−) | °′″ | hyp | sin | cos | tan -->
                        <Button Grid.Row="1" Grid.Column="0" Content="&#x2212;"
                                vm:ButtonExtensions.SecondaryLabel="&#x2190;" vm:ButtonExtensions.AlphaLabel="A"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="(-)"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="DMS"
                                vm:ButtonExtensions.SecondaryLabel="FACT" vm:ButtonExtensions.AlphaLabel="B"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="DMS" FontSize="13"
                                ToolTip="DMS = Degree / Minute / Second"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="hyp"
                                vm:ButtonExtensions.SecondaryLabel="Abs" vm:ButtonExtensions.AlphaLabel="C"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="HYP"/>
                        <Button Grid.Row="1" Grid.Column="3" Content="sin"
                                vm:ButtonExtensions.SecondaryLabel="sin&#x207B;&#x00B9;" vm:ButtonExtensions.AlphaLabel="D"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="sin"/>
                        <Button Grid.Row="1" Grid.Column="4" Content="cos"
                                vm:ButtonExtensions.SecondaryLabel="cos&#x207B;&#x00B9;" vm:ButtonExtensions.AlphaLabel="E"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="cos"/>
                        <Button Grid.Row="1" Grid.Column="5" Content="tan"
                                vm:ButtonExtensions.SecondaryLabel="tan&#x207B;&#x00B9;" vm:ButtonExtensions.AlphaLabel="F"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="tan"/>

                        <!-- Sci Row 3: RCL | ENG | ( | ) | S⇔D | M+ -->
                        <Button Grid.Row="2" Grid.Column="0" Content="RCL"
                                vm:ButtonExtensions.SecondaryLabel="STO"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="RCL"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="ENG"
                                vm:ButtonExtensions.SecondaryLabel="&#x2190;" vm:ButtonExtensions.AlphaLabel="i"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="ENG"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="("
                                vm:ButtonExtensions.SecondaryLabel="%" vm:ButtonExtensions.AlphaLabel="X"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="("/>
                        <Button Grid.Row="2" Grid.Column="3" Content=")"
                                vm:ButtonExtensions.SecondaryLabel="," vm:ButtonExtensions.AlphaLabel="Y"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter=")"/>
                        <Button Grid.Row="2" Grid.Column="4" Content="S&#x21D4;D"
                                vm:ButtonExtensions.SecondaryLabel="a b/c" vm:ButtonExtensions.AlphaLabel="d/c"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="SD" FontSize="11"/>
                        <Button Grid.Row="2" Grid.Column="5" Content="M+"
                                vm:ButtonExtensions.SecondaryLabel="M&#x2212;" vm:ButtonExtensions.AlphaLabel="M"
                                Style="{StaticResource ScienceKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="M+"/>
                    </Grid>

                    <!-- ===== ZONE 3: Numeric/Operator Grid (5 cols × 4 rows) ===== -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Num Row 1: 7 | 8 | 9 | DEL | AC -->
                        <Button Grid.Row="0" Grid.Column="0" Content="7"
                                vm:ButtonExtensions.SecondaryLabel="CONST"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="7"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="8"
                                vm:ButtonExtensions.SecondaryLabel="CONV"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="8"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="9"
                                vm:ButtonExtensions.SecondaryLabel="CLR"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="9"/>
                        <Button Grid.Row="0" Grid.Column="3" Content="DEL"
                                vm:ButtonExtensions.SecondaryLabel="INS" Style="{StaticResource ControlKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="DEL"/>
                        <Button Grid.Row="0" Grid.Column="4" Content="AC"
                                vm:ButtonExtensions.SecondaryLabel="OFF" Style="{StaticResource ControlKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="AC"/>

                        <!-- Num Row 2: 4 | 5 | 6 | × | ÷ -->
                        <Button Grid.Row="1" Grid.Column="0" Content="4"
                                vm:ButtonExtensions.SecondaryLabel="MATRIX"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5"
                                vm:ButtonExtensions.SecondaryLabel="VECTOR"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6"
                                vm:ButtonExtensions.SecondaryLabel="VERIFY"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="6"/>
                        <Button Grid.Row="1" Grid.Column="3" Content="&#x00D7;"
                                vm:ButtonExtensions.SecondaryLabel="nPr" vm:ButtonExtensions.AlphaLabel="GCD"
                                Style="{StaticResource OperatorKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="×"/>
                        <Button Grid.Row="1" Grid.Column="4" Content="&#x00F7;"
                                vm:ButtonExtensions.SecondaryLabel="nCr" vm:ButtonExtensions.AlphaLabel="LCM"
                                Style="{StaticResource OperatorKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="÷"/>

                        <!-- Num Row 3: 1 | 2 | 3 | + | − -->
                        <Button Grid.Row="2" Grid.Column="0" Content="1"
                                vm:ButtonExtensions.SecondaryLabel="STAT"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="1"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="2"
                                vm:ButtonExtensions.SecondaryLabel="CMPLX"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="2"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="3"
                                vm:ButtonExtensions.SecondaryLabel="BASE"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="3"/>
                        <Button Grid.Row="2" Grid.Column="3" Content="+"
                                vm:ButtonExtensions.SecondaryLabel="Pol" vm:ButtonExtensions.AlphaLabel="Int"
                                Style="{StaticResource OperatorKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="+"/>
                        <Button Grid.Row="2" Grid.Column="4" Content="&#x2212;"
                                vm:ButtonExtensions.SecondaryLabel="Rec" vm:ButtonExtensions.AlphaLabel="Intg"
                                Style="{StaticResource OperatorKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="−"/>

                        <!-- Num Row 4: 0 | . | ×10ˣ | Ans | = -->
                        <Button Grid.Row="3" Grid.Column="0" Content="0"
                                vm:ButtonExtensions.SecondaryLabel="Rnd"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="0"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="."
                                vm:ButtonExtensions.SecondaryLabel="Ran#" vm:ButtonExtensions.AlphaLabel="RanInt"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="."/>
                        <Button Grid.Row="3" Grid.Column="2" Content="&#x00D7;10&#x02E3;"
                                vm:ButtonExtensions.SecondaryLabel="&#x03C0;" vm:ButtonExtensions.AlphaLabel="e"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="×10^"/>
                        <Button Grid.Row="3" Grid.Column="3" Content="Ans"
                                vm:ButtonExtensions.SecondaryLabel="DRG&#x25B6;" vm:ButtonExtensions.AlphaLabel="PreAns"
                                Style="{StaticResource NumberKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="Ans"/>
                        <Button Grid.Row="3" Grid.Column="4" Content="="
                                Style="{StaticResource OperatorKeyStyle}"
                                Command="{Binding InputCommand}" CommandParameter="="/>
                    </Grid>
                </Grid>

                <!-- ========== ROW 4: FOOTER (curved base) ========== -->
                <Border Grid.Row="4" Height="16" Margin="28,4,28,0"
                        Background="#0D0F11" CornerRadius="0,0,120,120">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#000000" Opacity="0.18" Direction="0"/>
                    </Border.Effect>
                </Border>
            </Grid>
        </Grid>
    </Border>
    </Border>
</Window>
